<div class="mmm-valorant-banner-container">
  {% if matches.length === 0 %}
    <div class="mmm-valorant-empty">
      {{ 'NO_MATCHES_FOUND' | translate }}
    </div>
  {% else %}
    <div class="mmm-valorant-banner-wrapper">
      <!-- Render matches twice for seamless scrolling loop -->
      {% for iteration in range(2) %}
        {% for match in matches %}
          <div class="mmm-valorant-match">
            <!-- Match Header: Date and Time -->
            <div class="mmm-valorant-match-header">
              <div class="mmm-valorant-match-date">{{ match.displayDayOfWeek }}</div>
              {% if match.isLive %}
                <div class="mmm-valorant-match-time">LIVE</div>
              {% else %}
                <div class="mmm-valorant-match-time">{{ match.displayHour }}:{{ match.displayMinute }}</div>
              {% endif %}
            </div>

            <!-- Match Score Line -->
            <div class="mmm-valorant-match-content">
              <span class="mmm-valorant-team-code">{{ match.match.teams[0].code }}</span>
              
              {% if match.isFinished and match.match.teams[0].result %}
                <span class="mmm-valorant-score">{{ match.match.teams[0].result.gameWins }}</span>
              {% endif %}
              
              <span class="mmm-valorant-vs">vs</span>
              
              {% if match.isFinished and match.match.teams[1].result %}
                <span class="mmm-valorant-score">{{ match.match.teams[1].result.gameWins }}</span>
              {% endif %}
              
              <span class="mmm-valorant-team-code">{{ match.match.teams[1].code }}</span>
            </div>
          </div>

          <!-- Separator between matches -->
          {% if not loop.last or iteration === 0 %}
            <div class="mmm-valorant-separator"></div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  {% endif %}
</div>
